# Lister runtime config. All values are OPTIONAL — Lister is local-first and
# needs no env to run. SMTP credentials are entered in the app UI, not here.

# Internal container port (must match docker-compose + Dockerfile).
PORT=3000

# Set to "false" ONLY to allow self-signed SMTP certs (dev/testing). Leave unset
# or "true" in production.
# SMTP_REJECT_UNAUTHORIZED=true
